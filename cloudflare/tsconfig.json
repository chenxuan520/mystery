{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "../src/case/**/*.ts",
    "../src/chat/**/*.ts",
    "../src/judgement/**/*.ts"
  ]
}
